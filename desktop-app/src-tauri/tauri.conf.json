{
  "$schema": "https://raw.githubusercontent.com/nicokosi/tauri/main/tooling/cli/schema.json",
  "productName": "SMTP Lab",
  "version": "0.1.0",
  "identifier": "com.smtplab.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "SMTP Lab — SMTP Testing & Diagnostics",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
